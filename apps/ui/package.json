{
  "name": "@app/ui",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../.env vite --mode ssr",
    "build": "bun --env-file=../../.env qwik build",
    "build.client": "bun --env-file=../../.env vite build",
    "build.preview": "bun --env-file=../../.env vite build --mode ssr",
    "build.server": "bun --env-file=../../.env vite build --ssr src/entry.ssr.tsx",
    "build:client": "bun --env-file=../../.env vite build",
    "build:preview": "bun --env-file=../../.env vite build --mode ssr",
    "build:server": "bun --env-file=../../.env vite build --ssr src/entry.ssr.tsx",
    "preview": "bun --env-file=../../.env qwik build preview && bun --env-file=../../.env vite preview",
    "test": "bun --env-file=../../.env vitest run",
    "test:watch": "bun --env-file=../../.env vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@builder.io/qwik": "^1.19.2",
    "@builder.io/qwik-city": "^1.19.2",
    "@elysia/eden": "^1.4.10",
    "@app/types": "workspace:*",
    "@app/schemas": "workspace:*",
    "@app/utils": "workspace:*"
  },
  "devDependencies": {
    "eslint-plugin-qwik": "latest",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.5"
  },
  "paths": {
    "@app/api/*": "../../services/api/src/*",
    "@app/types/*": "../../packages/types/src/*",
    "@app/schemas/*": "../../packages/schemas/src/*",
    "@app/utils/*": "../../packages/utils/src/*"
  }
}
