# Local test defaults (replace values for your environment)
# API runtime
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
# JWT
JWT_SECRET=local_test_jwt_secret_change_me
# DB User Config
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app_db
ADMIN_DB_USER=admin
ADMIN_DB_PASSWORD=replace-with-a-long-random-password
MIGRATOR_DB_USER=db_migrator
MIGRATOR_DB_PASSWORD=replace-with-a-long-random-password
APP_DB_USER=app_user
APP_DB_PASSWORD=replace-with-a-long-random-password
# Redis Config
REDIS_URL=redis://localhost:6379
REDIS_USERNAME=default
REDIS_PASSWORD=replace-with-a-long-random-password
# Email Transport
EMAIL_PASSWORD=local_test_email_password
