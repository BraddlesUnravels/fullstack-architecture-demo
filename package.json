{
  "name": "job-application-tracker",
  "version": "0.1.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "bun-types": "^1.3.13",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.46.2",
    "typescript": "^6.0.3"
  },
  "$schema": "https://json.schemastore.org/package",
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "*.{md,css,tailwindcss,json,yml,yaml}": "prettier --write"
  },
  "private": false,
  "scripts": {
    "start": "bun run --filter '@app/db' infra:up && (bun run dev:api & bun run dev:ui & wait)",
    "init": "cp .env.example .env && bun i && bun run dev:db:init && bun run dev:api && bun run dev:ui",
    "reset": "bun run dev:db:reset && bun run dev:api && bun run dev:ui",
    "stop": "bun run --filter '@app/api' down && bun run --filter '@app/ui' down && bun run --filter '@app/db' infra:down",
    "dev:ui": "bun run --filter '@app/ui' dev",
    "dev:db:init": "bun run --filter '@app/db' init",
    "dev:db:reset": "bun run --filter '@app/db' hot:reset",
    "dev:db": "bun run --filter '@app/db' hot:reset",
    "dev:api": "bun run --filter '@app/api' dev",
    "typecheck": "bun run --filter '@app/*' typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "bun run --filter '@app/*' lint",
    "prepare": "husky"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ]
}
