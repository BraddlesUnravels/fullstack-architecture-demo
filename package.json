{
  "name": "job-application-tracker",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter='./apps/*' dev & bun run --filter='./services/*' dev",
    "dev:ui": "bun run --filter='./apps/*' dev",
    "dev:api": "bun run --filter='./services/*' dev",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,css,md,ts,tailwindcss,tsx}": "prettier --write"
  },
  "dependencies": {
    "job-application-tracker": "."
  }
}
