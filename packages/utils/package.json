{
  "name": "@app/utils",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@app/db": "workspace:*",
    "@app/schemas": "workspace:*",
    "@app/types": "workspace:*"
  },
  "paths": {
    "@app/types/*": "../types/src/*",
    "@app/schemas/*": "../schemas/src/*",
    "@app/db/*": "../db/src/*"
  },
  "devDependencies": {
    "argon2": "^0.44.0"
  }
}
