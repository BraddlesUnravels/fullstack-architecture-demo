{
  "name": "@app/redis",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "infra:up": "docker compose --env-file ../../.env -f ../../docker/docker-compose-redis.dev.yml up -d",
    "infra:down": "docker compose --env-file ../../.env -f ../../docker/docker-compose-redis.dev.yml down",
    "infra:reset": "docker compose --env-file ../../.env -f ../../docker/docker-compose-redis.dev.yml down -v",
    "redis:cli": "docker exec -it app_redis redis-cli",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@app/constants": "workspace:*",
    "@app/types": "workspace:*",
    "redis": "^6.1.0"
  },
  "paths": {
    "@app/types/*": "../types/src/*",
    "@app/constants": "../constants/src/index.ts"
  }
}
