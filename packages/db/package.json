{
  "name": "@app/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "init": "bun run infra:up && run run db:generate && bun run db:migrate && bun run db:seed",
    "hot:reset": "bun run infra:reset && bun run infra:up && bun run db:generate && bun run db:migrate && bun run db:seed",
    "infra:up": "docker-compose -f ../../docker/docker-compose-db.dev.yml up -d",
    "infra:down": "docker-compose -f ../../docker/docker-compose-db.dev.yml down",
    "infra:reset": "docker-compose -f ../../docker/docker-compose-db.dev.yml down -v",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun src/seed/index.ts",
    "db:test": "bun src/__tests__/db.test.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@app/constants": "workspace:*",
    "@app/schemas": "workspace:*",
    "@app/types": "workspace:*",
    "@app/utils": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
