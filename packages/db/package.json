{
  "name": "@app/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "init": "bun run infra:up && bun run db:generate && bun run db:migrate && bun run db:grant && bun run db:seed",
    "hot:reset": "bun run infra:reset && bun run infra:up && bun run wait:15 && bun run db:migrate && bun run db:grant && bun run db:seed",
    "infra:up": "docker compose -f ../../docker/docker-compose-db.dev.yml up -d",
    "infra:down": "docker compose -f ../../docker/docker-compose-db.dev.yml down",
    "infra:reset": "docker compose -f ../../docker/docker-compose-db.dev.yml down -v",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env src/scripts/apply-migrations.ts",
    "db:grant": "bun --env-file=../../.env src/scripts/grant-app-permissions.ts",
    "db:migrate:kit": "bun --env-file=../../.env drizzle-kit migrate",
    "db:apply-migrations": "bun --env-file=../../.env src/scripts/apply-migrations.ts",
    "db:seed": "bun --env-file=../../.env src/seed/index.ts --users=1000 --companies=250 --max-applications-per-user=5 --batch-size=200 --mode=deterministic --seed=20260719 --truncate=true",
    "wait:15": "bun -e \"await new Promise(r => setTimeout(r, 15000))\"",
    "db:test": "bun --env-file=../../.env src/__tests__/db.test.ts",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@app/constants": "workspace:*",
    "@app/schemas": "workspace:*",
    "@app/types": "workspace:*",
    "@app/utils": "workspace:*",
    "@faker-js/faker": "^10.5.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}
