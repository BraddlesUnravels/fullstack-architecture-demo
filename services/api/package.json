{
  "name": "@app/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun --env-file=../../.env run --watch src/index.ts",
    "down": "bun --env-file=../../.env run src/scripts/down.ts",
    "build": "tsc --noEmit",
    "start": "bun --env-file=../../.env run src/index.ts",
    "test": "bun --env-file=../../.env vitest run",
    "test:watch": "bun --env-file=../../.env vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@app/db": "workspace:*",
    "@app/schemas": "workspace:*",
    "@app/types": "workspace:*",
    "@app/utils": "workspace:*",
    "@app/constants": "workspace:*",
    "@elysia/eden": "^1.4.10",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "argon2": "^0.44.0",
    "elysia": "^1.4.28",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1"
  },
  "paths": {
    "@app/db/*": "../db/src/*",
    "@app/schemas/*": "../../packages/schemas/src/*",
    "@app/types/*": "../../packages/types/src/*",
    "@app/utils/*": "../../packages/utils/src/*",
    "@app/constants/*": "../../packages/constants/src/*"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "pino-pretty": "^13.1.3"
  }
}
