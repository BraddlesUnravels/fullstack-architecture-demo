{
  "name": "@app/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "bun run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@app/db": "workspace:*",
    "@app/schemas": "workspace:*",
    "@app/types": "workspace:*",
    "@app/utils": "workspace:*",
    "@elysia/eden": "^1.4.10",
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "argon2": "^0.44.0",
    "elysia": "^1.4.28",
    "pino": "^10.3.1"
  },
  "paths": {
    "@app/db/*": "../db/src/*",
    "@app/schemas/*": "../../packages/schemas/src/*",
    "@app/types/*": "../../packages/types/src/*",
    "@app/utils/*": "../../packages/utils/src/*"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
